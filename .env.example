# Required
AUTH_TOKEN=your-secret-token-here

# Database: "better-sqlite3" or "mysql2"
DB_CLIENT=better-sqlite3

# MySQL connection (only when DB_CLIENT=mysql2)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=tsmanager
DB_PASS=tsmanager_password
DB_NAME=tsmanager

# Server
PORT=3000

# Public IP (auto-detected if empty)
PUBLIC_IP=
CUSTOM_DOMAIN=

# Docker
TS_IMAGE=teamspeak
PORT_RANGE_START=20000
